{
  "name": "voice-agent-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Customer Voice Calling Agent POC — OpenAI Realtime API over WebRTC",
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
