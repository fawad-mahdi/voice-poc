# ── Required ──────────────────────────────────────────────────────────────
# Standard OpenAI API key. Used ONLY on the server to mint short-lived
# ephemeral tokens (ek_...) and to generate post-call summaries.
# The browser never sees this key.
OPENAI_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────────
# Realtime model. gpt-realtime-2 is the GA speech-to-speech model.
REALTIME_MODEL=gpt-realtime-2

# Output voice. Options at time of writing: marin, cedar, alloy, echo,
# shimmer, verse, coral, sage, ash, ballad.
REALTIME_VOICE=marin

# Model used for the post-call summary + disposition tagging.
SUMMARY_MODEL=gpt-4o-mini

# Server-side VAD: how long a pause (ms) before the model treats the
# customer's turn as finished. 400ms ≈ natural conversational gap.
VAD_SILENCE_MS=400

# Company name injected into the agent persona.
COMPANY_NAME=Northwind Retail

# Server port (the Vite dev server proxies /api here).
PORT=3001
